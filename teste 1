local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

local COLOR_BG = Color3.fromRGB(8, 7, 11)        
local COLOR_MAIN = Color3.fromRGB(157, 78, 221)   
local COLOR_LIGHT = Color3.fromRGB(240, 230, 255) 
local COLOR_ACCENT = Color3.fromRGB(224, 170, 255) 

local loadGui = Instance.new("ScreenGui")
loadGui.Name = "ShidoLoading_System"
loadGui.IgnoreGuiInset = true
loadGui.DisplayOrder = 9999999 
loadGui.Parent = playerGui

local mainBackground = Instance.new("Frame")
mainBackground.Size = UDim2.fromScale(1, 1)
mainBackground.BackgroundColor3 = COLOR_BG
mainBackground.BorderSizePixel = 0
mainBackground.Parent = loadGui

local particleContainer = Instance.new("Frame")
particleContainer.Size = UDim2.fromScale(1, 1)
particleContainer.BackgroundTransparency = 1
particleContainer.Parent = mainBackground

local function spawnParticle()
	if not mainBackground.Parent then return end
	local p = Instance.new("Frame")
	p.Size = UDim2.fromOffset(math.random(2, 4), math.random(2, 4))
	p.Position = UDim2.fromScale(math.random(), math.random(0.2, 0.8))
	p.BackgroundColor3 = math.random(1, 2) == 1 and COLOR_MAIN or COLOR_LIGHT
	p.BackgroundTransparency = 0.4
	p.BorderSizePixel = 0
	p.Parent = particleContainer
	
	Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
	
	local randomX = p.Position.X.Scale + (math.random(-5, 5) / 100)
	local randomY = p.Position.Y.Scale - (math.random(1, 3) / 10)
	
	local tweenInfo = TweenInfo.new(math.random(3, 6), Enum.EasingStyle.Linear)
	local tween = TweenService:Create(p, tweenInfo, {
		Position = UDim2.fromScale(randomX, randomY),
		BackgroundTransparency = 1
	})
	tween:Play()
	tween.Completed:Connect(function() p:Destroy() end)
end

task.spawn(function()
	for i = 1, 25 do spawnParticle() end
	while mainBackground.Parent and mainBackground.Visible do
		spawnParticle()
		task.wait(0.2)
	end
end)

local centerContainer = Instance.new("Frame")
centerContainer.Size = isMobile and UDim2.fromScale(0.8, 0.4) or UDim2.fromScale(0.4, 0.4)
centerContainer.Position = UDim2.fromScale(0.5, 0.45)
centerContainer.AnchorPoint = Vector2.new(0.5, 0.5)
centerContainer.BackgroundTransparency = 1
centerContainer.Parent = mainBackground

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.fromScale(1, 0.4)
titleLabel.Position = UDim2.fromScale(0, 0.1)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "BY SHIDO"
titleLabel.Font = Enum.Font.GothamBold
titleLabel.TextColor3 = COLOR_LIGHT
titleLabel.TextSize = isMobile and 38 or 52
titleLabel.TextStrokeTransparency = 0.8
titleLabel.TextStrokeColor3 = COLOR_MAIN
titleLabel.Parent = centerContainer

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.fromScale(1, 0.15)
statusLabel.Position = UDim2.fromScale(0, 0.5)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = ""
statusLabel.Font = Enum.Font.Code -- Utilisation d'une police "Vieux PC/Code"
statusLabel.TextColor3 = COLOR_ACCENT
statusLabel.TextSize = isMobile and 14 or 16
statusLabel.TextXAlignment = Enum.TextXAlignment.Center
statusLabel.Parent = centerContainer

local barBackground = Instance.new("Frame")
barBackground.Size = UDim2.fromScale(0.8, 0.04)
barBackground.Position = UDim2.fromScale(0.1, 0.75)
barBackground.BackgroundColor3 = Color3.fromRGB(20, 18, 26)
barBackground.BorderSizePixel = 0
barBackground.Parent = centerContainer
Instance.new("UICorner", barBackground).CornerRadius = UDim.new(1, 0)

local barProgress = Instance.new("Frame")
barProgress.Size = UDim2.fromScale(0, 1)
barProgress.BackgroundColor3 = COLOR_MAIN
barProgress.BorderSizePixel = 0
barProgress.Parent = barBackground
Instance.new("UICorner", barProgress).CornerRadius = UDim.new(1, 0)

local gradient = Instance.new("UIGradient", barProgress)
gradient.Color = ColorSequence.new(COLOR_MAIN, COLOR_ACCENT)

task.spawn(function()
	while mainBackground.Parent and mainBackground.Visible do
		local tweenGlow = TweenService:Create(titleLabel, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingStyle.InOut), {
			TextColor3 = COLOR_ACCENT,
			TextStrokeTransparency = 0.5
		})
		tweenGlow:Play()
		tweenGlow.Completed:Wait()
		
		local tweenNormal = TweenService:Create(titleLabel, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingStyle.InOut), {
			TextColor3 = COLOR_LIGHT,
			TextStrokeTransparency = 0.8
		})
		tweenNormal:Play()
		tweenNormal.Completed:Wait()
	end
end)

local cursorOn = true
local currentFullText = ""

task.spawn(function()
	while mainBackground.Parent and mainBackground.Visible do
		cursorOn = not cursorOn
		if string.len(currentFullText) > 0 then
			statusLabel.Text = currentFullText .. (cursorOn and "_" or " ")
		end
		task.wait(0.15) -- Vitesse de clignotement du curseur
	end
end)

local function typeWrite(targetText)
	currentFullText = ""
	for i = 1, string.len(targetText) do
		currentFullText = string.sub(targetText, 1, i)
		statusLabel.Text = currentFullText .. (cursorOn and "_" or " ")
		task.wait(0.03) -- Vitesse d'écriture lettre par lettre
	end
end

local loadingSteps = {
	{progress = 0.15, text = "> Loading Shido Engine..."},
	{progress = 0.40, text = "> Bypassing Roblox UI Constraints..."},
	{progress = 0.65, text = "> Fetching Remote Security Handshakes..."},
	{progress = 0.85, text = "> Optimizing Anti-Lag Systems..."},
	{progress = 1.00, text = "> Core Loaded. Successfully Injection!"}
}

task.spawn(function()
	for _, step in ipairs(loadingSteps) do

		typeWrite(step.text)

		local tweenBar = TweenService:Create(barProgress, TweenInfo.new(math.random(5, 10)/10, Enum.EasingStyle.Quad, Enum.EasingOut), {
			Size = UDim2.fromScale(step.progress, 1)
		})
		tweenBar:Play()
		tweenBar.Completed:Wait()
		
		task.wait(0.4) -- Pause sur le message écrit
	end

	typeWrite("> Welcome.")
	task.wait(0.6)

	local fadeOutInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingMode.Out)
	local fadeTween = TweenService:Create(mainBackground, fadeOutInfo, {BackgroundTransparency = 1})

	for _, child in ipairs(centerContainer:GetChildren()) do
		if child:IsA("TextLabel") then
			TweenService:Create(child, fadeOutInfo, {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
		elseif child:IsA("Frame") then
			TweenService:Create(child, fadeOutInfo, {BackgroundTransparency = 1}):Play()
			if child:FindFirstChildOfClass("Frame") then
				TweenService:Create(child:FindFirstChildOfClass("Frame"), fadeOutInfo, {BackgroundTransparency = 1}):Play()
			end
		end
	end

	fadeTween:Play()
	fadeTween.Completed:Wait()

	loadGui:Destroy()
end)
