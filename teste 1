toggleBtn.TextColor3 = COLOR_GLOW
toggleBtn.Font = Enum.Font.Code
toggleBtn.TextSize = 16
toggleBtn.Text = "[O]"
toggleBtn.Parent = gui

local isMenuOpen = false
local isAnimating = false

-- 📺 ANIMATION "VIEILLE TÉLÉ" (Resserrement vertical vers le milieu)
local function toggleDashboard()
	if isAnimating then return end 
	isAnimating = true
	
	if not isMenuOpen then
		blackFrame.Visible = true
		toggleBtn.Text = "[X]"
		toggleBtn.TextColor3 = COLOR_ALERT
		
		-- Allumage : Ouverture du haut et du bas depuis le centre
		local openTween = TweenService:Create(blackFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingMode.Out), {
			Size = UDim2.fromScale(1, 1),
			Position = UDim2.fromScale(0, 0)
		})
		openTween:Play()
		task.wait(0.3)
		isMenuOpen = true
	else
		toggleBtn.Text = "[O]"
		toggleBtn.TextColor3 = COLOR_GLOW
		
		-- Extinction : Compression de la hauteur vers la ligne du milieu
		local closeTween = TweenService:Create(blackFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingMode.In), {
			Size = UDim2.fromScale(1, 0),
			Position = UDim2.fromScale(0, 0.5)
		})
		closeTween:Play()
		task.wait(0.3)
		
		blackFrame.Visible = false
		isMenuOpen = false
	end
	
	isAnimating = false
end

toggleBtn.MouseButton1Click:Connect(toggleDashboard)

-- Touche de secours [K] pour PC
UserInputService.InputBegan:Connect(function(input, gpe)
	if not gpe and input.KeyCode == Enum.KeyCode.K then 
		toggleDashboard() 
	end
end)

