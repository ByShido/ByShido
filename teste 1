local function spawnParticle()
	if not loadBackground.Parent then return end
	local p = Instance.new("Frame")
	p.Size = UDim2.fromOffset(math.random(2, 3), math.random(2, 3))
	p.Position = UDim2.fromScale(math.random(), math.random(0.1, 0.9))
	p.BackgroundColor3 = math.random(1, 2) == 1 and COLOR_GLOW or COLOR_TEXT
	p.BackgroundTransparency = 0.5
	p.BorderSizePixel = 0
	p.Parent = particleContainer
	
	local randomX = p.Position.X.Scale + (math.random(-3, 3) / 100)
	local randomY = p.Position.Y.Scale - (math.random(1, 4) / 10)
	
	local tween = TweenService:Create(p, TweenInfo.new(math.random(4, 7), Enum.EasingStyle.Linear), {
		Position = UDim2.fromScale(randomX, randomY),
		BackgroundTransparency = 1
	})
	tween:Play()
	tween.Completed:Connect(function() p:Destroy() end)
end

task.spawn(function()
	for i = 1, 20 do spawnParticle() end
	while loadBackground.Parent and loadBackground.Visible do
		spawnParticle()
		task.wait(0.25)
	end
end)

