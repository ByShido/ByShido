-- ========================================================================
-- CONTROLE DU BOUTON (INDIRECIABLE ET TOTALEMENT ASYNC)
-- ========================================================================
local isMenuOpen = false
local isAnimating = false

local function toggleDashboard()
	if isAnimating then return end
	isAnimating = true
	
	if not isMenuOpen then
		blackFrame.Visible = true
		pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false) end)
		toggleBtn.Text = "[X]"
		toggleBtn.TextColor3 = COLOR_ALERT
		btnStroke.Color = COLOR_ALERT
		
		local openTween = TweenService:Create(blackFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingMode.Out), {
			Size = UDim2.fromScale(1, 1),
			Position = UDim2.fromScale(0, 0)
		})
		openTween:Play()
		openTween.Completed:Wait()
		isMenuOpen = true
	else
		toggleBtn.Text = "[O]"
		toggleBtn.TextColor3 = COLOR_GLOW
		btnStroke.Color = COLOR_GLOW
		
		local closeTween = TweenService:Create(blackFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingMode.In), {
			Size = UDim2.fromScale(1, 0),
			Position = UDim2.fromScale(0, 0.5)
		})
		closeTween:Play()
		closeTween.Completed:Wait()
		
		blackFrame.Visible = false
		pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true) end)
		isMenuOpen = false
	end
	isAnimating = false
end

toggleBtn.MouseButton1Click:Connect(toggleDashboard)
UserInputService.InputBegan:Connect(function(input, gpe)
	if not gpe and input.KeyCode == Enum.KeyCode.K then toggleDashboard() end
end)

