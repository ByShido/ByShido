-- 🧠 TRADUCTION DES EVENEMENTS RESEAU (ASYNCHRONE)
local rollSession = 0
local currentHour = os.date("*t").hour
rollsByHour[currentHour] = 0

local function spawnToast(itemName)
	notificationArea:ClearAllChildren()
	local toast = Instance.new("TextLabel")
	toast.Size = UDim2.fromScale(1, 1)
	toast.BackgroundTransparency = 1
	toast.TextColor3 = COLOR_TEXT
	toast.Font = Enum.Font.Code
	toast.TextScaled = true
	toast.Text = ">> DROPPED: " .. string.upper(itemName)
	toast.Parent = notificationArea
end

task.spawn(function()
	local interfaceFolder = ReplicatedStorage:WaitForChild("Interface", 10)
	local remote = interfaceFolder and interfaceFolder:WaitForChild("UpdateMountInventory", 10)
	
	if remote then
		remote.OnClientEvent:Connect(function(name, amount, action)
			if typeof(action) == "string" and string.lower(action):find("sell") then return end

			rollSession += 1
			sessionRollLabel.Text = "SES_ROLL: " .. rollSession
			task.spawn(spawnToast, tostring(name))

			historyData[name] = (historyData[name] or 0) + 1
			updateHistoryUI(name)

			local now = os.date("*t")
			if now.hour ~= currentHour then
				currentHour = now.hour
				rollsByHour[currentHour] = 0
			end
			rollsByHour[currentHour] = (rollsByHour[currentHour] or 0) + 1
			updateHourUI(currentHour, rollsByHour[currentHour])
		end)
	end
end)

-- ⏳ SYSTEM LOOP MONITORING (1 SEC)
local startTime = os.time()

task.spawn(function()
	updateHourUI(currentHour, 0)
	while true do
		local now = os.date("*t")
		clockLabel.Text = string.format("SYS_T: %02d:%02d:%02d", now.hour, now.min, now.sec)

		local elapsed = os.time() - startTime
		local h = math.floor(elapsed / 3600)
		local m = math.floor((elapsed % 3600) / 60)
		timeLabel.Text = string.format("UPTIME: %02dh %02dm", h, m)

		local leaderstats = player:FindFirstChild("leaderstats")
		local totalRollsValue = leaderstats and leaderstats:FindFirstChild("Rolls")
		if totalRollsValue and totalRollsValue:IsA("ValueBase") then
			totalRollLabel.Text = "TOTAL_R: " .. tostring(totalRollsValue.Value)
		end

		-- Batterie Phosphore / Rétro
		local batteryLevel = math.round(GuiService:GetBatteryLevel() * 100)
		batteryLabel.Text = string.format("BATTERY: %d%%", batteryLevel)
		if batteryLevel > 50 then batteryLabel.TextColor3 = COLOR_SUCCESS
		elseif batteryLevel > 20 then batteryLabel.TextColor3 = COLOR_TEXT
		else batteryLabel.TextColor3 = COLOR_ALERT end

		-- Réseau Ping
		local ping = math.round(Stats.Network.ServerToClientPing:GetValue() * 100)
		perfLabel.Text = string.format("PING: %dms", ping)
		if ping < 100 then perfLabel.TextColor3 = COLOR_SUCCESS
		elseif ping < 200 then perfLabel.TextColor3 = COLOR_TEXT
		else perfLabel.TextColor3 = COLOR_ALERT end

		task.wait(1)
	end
end)
