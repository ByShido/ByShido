local historyData = {}
local rollsByHour = {}
local rollSession = 0
local currentHour = os.date("*t").hour
rollsByHour[currentHour] = 0

local function updateHistoryUI(name)
	local existingRow = scroll:FindFirstChild(name)
	if existingRow then
		existingRow.TextLabel.Text = string.format("- %s [x%d]", string.upper(name), historyData[name])
	else
		local row = Instance.new("Frame")
		row.Name = name
		row.Size = UDim2.new(1, -6, 0, isMobile and 34 or 26)
		row.BackgroundColor3 = COLOR_CARD
		row.BorderSizePixel = 0
		row.Parent = scroll
		
		local label = Instance.new("TextLabel")
		label.Name = "TextLabel"
		label.Size = UDim2.fromScale(0.95, 1)
		label.Position = UDim2.fromScale(0.05, 0)
		label.BackgroundTransparency = 1
		label.TextColor3 = COLOR_TEXT
		label.Font = Enum.Font.Code
		label.TextSize = isMobile and 12 or 11
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Text = string.format("- %s [x%d]", string.upper(name), historyData[name])
		label.Parent = row
	end
	scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
end

local function updateHourUI(hour, count)
	local hourKey = tostring(hour) .. "H"
	local existingRow = hourScroll:FindFirstChild(hourKey)
	if existingRow then
		existingRow.TextLabel.Text = string.format("- TIMELOG %s : %s ROLLS", hourKey, tostring(count))
	else
		local row = Instance.new("Frame")
		row.Name = hourKey
		row.Size = UDim2.new(1, -6, 0, isMobile and 34 or 26)
		row.BackgroundColor3 = COLOR_CARD
		row.BorderSizePixel = 0
		row.Parent = hourScroll
		
		local label = Instance.new("TextLabel")
		label.Name = "TextLabel"
		label.Size = UDim2.fromScale(0.95, 1)
		label.Position = UDim2.fromScale(0.05, 0)
		label.BackgroundTransparency = 1
		label.TextColor3 = COLOR_GLOW
		label.Font = Enum.Font.Code
		label.TextSize = isMobile and 12 or 11
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Text = string.format("- TIMELOG %s : %s ROLLS", hourKey, tostring(count))
		label.Parent = row
	end
	hourScroll.CanvasSize = UDim2.new(0, 0, 0, hourListLayout.AbsoluteContentSize.Y + 10)
end

task.spawn(function()
	local interfaceFolder = ReplicatedStorage:WaitForChild("Interface", 5)
	local remote = interfaceFolder and interfaceFolder:WaitForChild("UpdateMountInventory", 5)
	if remote then
		remote.OnClientEvent:Connect(function(name, amount, action)
			if typeof(action) == "string" and string.lower(action):find("sell") then return end
			rollSession = rollSession + 1
			sessionRollLabel.Text = "SES_ROLL: " .. rollSession
			historyData[name] = (historyData[name] or 0) + 1
			updateHistoryUI(name)
			local now = os.date("*t")
			if now.hour ~= currentHour then currentHour = now.hour rollsByHour[currentHour] = 0 end
			rollsByHour[currentHour] = (rollsByHour[currentHour] or 0) + 1
			updateHourUI(currentHour, rollsByHour[currentHour])
		end)
	end
end)

-- Anti-Idle & Monitoring Loop
player.Idled:Connect(function()
	pcall(function()
		VirtualUser:CaptureController()
		VirtualUser:ClickButton2(Vector2.new(100, 100))
	end)
end)

local startTime = os.time()
task.spawn(function()
	updateHourUI(currentHour, 0)
	while true do
		local now = os.date("*t")
		clockLabel.Text = string.format("SYS_T: %02d:%02d:%02d", now.hour, now.min, now.sec)
		local elapsed = os.time() - startTime
		timeLabel.Text = string.format("UPTIME: %02dh %02dm", math.floor(elapsed / 3600), math.floor((elapsed % 3600) / 60))
		
		local leaderstats = player:FindFirstChild("leaderstats")
		local totalRollsValue = leaderstats and leaderstats:FindFirstChild("Rolls")
		if totalRollsValue then totalRollLabel.Text = "TOTAL_R: " .. tostring(totalRollsValue.Value) end
		
		batteryLabel.Text = string.format("BATTERY: %d%%", math.round(GuiService:GetBatteryLevel() * 100))
		perfLabel.Text = string.format("PING: %dms", math.round(Stats.Network.ServerToClientPing:GetValue() * 100))
		task.wait(1)
	end
end)
